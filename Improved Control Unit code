library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use ieee.std_logic_unsigned.all;

entity Control_Unit is
    Port ( Clk : in STD_LOGIC;
           valid_in : in STD_LOGIC;
           RESET : in STD_LOGIC;
           rom_addr : out STD_LOGIC_VECTOR (2 downto 0);
           mac_init : out STD_LOGIC;
           ram_addr : out STD_LOGIC_VECTOR (2 downto 0));
end Control_Unit;

architecture behavioral of Control_Unit is

    signal counter : std_logic_vector(2 downto 0) := "111";
    signal valid_in_check : std_logic := '1';    --works as a lock, that locks the control unit until a NEW valid_in signal arrives
    
begin
    
    control: process(Clk,RESET)
    begin
        if(RESET='1') then counter<="111"; mac_init<='0'; valid_in_check<='1';
        elsif(rising_edge(Clk)) then
            if(valid_in='1' and valid_in_check='1' and counter="111") then 
                mac_init<='1'; counter<="000"; valid_in_check<='0';  --valid_in detected, lock the control unit
            else mac_init<='0'; 
                if(counter/="111") then counter<=counter+1;
                end if;
                if(valid_in='0') then valid_in_check<='1';    --valid_in went 'low', unlock the control unit and wait for the next valid_in
                end if;
            end if;
        end if;
    end process control;
    
    rom_addr<=counter;
    ram_addr<=counter;
                
end behavioral;
